classDiagram
    class Owner {
        +string name
        +dict preferences
        +list~Pet~ pets
        +add_pet(pet) void
        +set_preference(key, value) void
        +filter_tasks(completed, pet_name) list~CareTask~
    }

    class Pet {
        +string name
        +string species
        +string breed
        +int age
        +string notes
        +list~CareTask~ tasks
        +string id
        +add_task(task) void
        +remove_task(task_id) void
        +get_tasks() list~CareTask~
    }

    class CareTask {
        +string title
        +string category
        +int duration_minutes
        +string priority
        +string time_window
        +string recurrence
        +bool is_flexible
        +bool completed
        +date due_date
        +string id
        +conflicts_with(other_task) bool
        +fits_in_window(start, end) bool
        +mark_done() void
        +create_next_occurrence(today) CareTask
    }

    class Constraints {
        +int available_minutes
        +time day_start
        +time day_end
        +list~tuple~ blackout_windows
        +dict owner_prefs
        +int used_minutes
        +from_owner(owner, day_start, day_end, available_minutes)$ Constraints
        +is_time_available(start, end) bool
        +use_minutes(minutes) void
        +remaining_minutes() int
    }

    class Scheduler {
        +string strategy
        +generate_plan(pet, constraints, plan_date) Plan
        +find_conflicts(plans) list~SchedulingConflict~
        +check_for_conflicts(plans) list~string~
        +sort_by_priority(tasks) list~CareTask~
        +filter_by_available_time(tasks, constraints) list~CareTask~
        +resolve_conflicts(tasks) list~CareTask~
        +explain_choice(task) string
        -_roll_over_recurring_tasks(pet, today) void
        -_resolve_window(task, constraints) tuple
        -_find_slot(task, constraints, plan) tuple
    }

    class ScheduledTask {
        +CareTask task
        +time start_time
        +time end_time
        +string reason
        +overlaps_with(other) bool
    }

    class Plan {
        +date plan_date
        +Pet pet
        +list~ScheduledTask~ scheduled_tasks
        +list~CareTask~ skipped_tasks
        +add(scheduled_task) void
        +to_summary() string
        +total_duration() int
    }

    class SchedulingConflict {
        +Pet pet_a
        +ScheduledTask scheduled_a
        +Pet pet_b
        +ScheduledTask scheduled_b
        +describe() string
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" CareTask : has
    Scheduler ..> Constraints : uses
    Scheduler ..> CareTask : consumes
    Scheduler --> Plan : produces
    Scheduler ..> SchedulingConflict : produces
    Plan "1" --> "many" ScheduledTask : contains
    ScheduledTask --> CareTask : wraps
    Plan --> Pet : for
    SchedulingConflict --> ScheduledTask : references
    SchedulingConflict --> Pet : references
